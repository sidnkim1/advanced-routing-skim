conf t

interface g0/3
  description to CE-RTR-2
  ip address 198.51.100.9 255.255.255.248
  no shutdown

router bgp 65501
  neighbor 198.51.100.10 next-hop-self
  neighbor 198.51.100.10 remote-as 65511

end
write memory

