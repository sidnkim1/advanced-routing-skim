enable
configure terminal

hostname BB-RTR-4

enable secret cisco
username cisco secret cisco

! --- Local Access ---
line con 0
  logging synchronous
  login local
  exit

line vty 0 4
  logging synchronous
  login local
  exit

! --- Loopback ---
interface loopback0
  ip address 10.255.35.5 255.255.255.255
  ip ospf 100 area 0

! --- OSPF Process ---
router ospf 100
  router-id 10.255.35.5
 
  ! Area 0 summary (core)
  area 0 range 10.35.0.0 255.255.255.192
 
  ! Area 1 summary (top-left cluster)
  area 1 range 10.35.1.64 255.255.255.224

  ! Area 2 summary (bottom-left cluster)
  area 2 range 10.35.2.96 255.255.255.224

! --- iBGP ---
router bgp 65501
  bgp log-neighbor-changes

  neighbor 10.255.35.1 remote-as 65501
  neighbor 10.255.35.6 remote-as 65501
  
  neighbor 10.255.35.1 update-source loopback0
  neighbor 10.255.35.6 update-source loopback0
  
  neighbor 10.255.35.1 next-hop-self
  neighbor 10.255.35.6 next-hop-self

! --- Interfaces ---
interface g0/0
  description to_CORE
  ip address 10.35.0.5 255.255.255.248
  ip ospf 100 area 0
  no shutdown

interface g0/1
  description to_BB-RTR-5
  ip address 10.35.0.17 255.255.255.252
  ip ospf 100 area 0
  no shutdown

interface g0/2
  description to_BB-RTR-1
  ip address 10.35.0.14 255.255.255.252
  ip ospf 100 area 0
  no shutdown

interface g0/4
  description to_LR-AR1-1
  ip address 10.35.1.73 255.255.255.252
  ip ospf 100 area 1
  no shutdown

interface g0/3
  description to_LR-AR1-2
  ip address 10.35.1.77 255.255.255.252
  ip ospf 100 area 1
  no shutdown

interface g0/5
  description to_LR-AR2-1
  ip address 10.35.2.97 255.255.255.252
  ip ospf 100 area 2
  no shutdown

interface g0/6
  description to_LR-AR2-2
  ip address 10.35.2.101 255.255.255.252
  ip ospf 100 area 2
  no shutdown

end
write memory
