  neighbor 10.255.35.12 route-reflector-client
  neighbor 10.255.35.13 route-reflector-client
  neighbor 10.255.35.14 route-reflector-client

! --- Interfaces ---
interface g0/0
  description to_core
  ip address 10.35.0.6 255.255.255.248
  ip ospf 100 area 0
  no shutdown

interface g0/1
  description to_BB-RTR-4
  ip address 10.35.0.18 255.255.255.252
  ip ospf 100 area 0
  no shutdown

interface g0/2
  description to_BB-RTR-3
  ip address 10.35.0.21 255.255.255.252
