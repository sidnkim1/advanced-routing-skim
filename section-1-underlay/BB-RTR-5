enable
configure terminal

hostname BB-RTR-5

enable secret cisco
username cisco secret cisco

! --- Local Access ---
line con 0
  logging synchronous
  login local
  exit

line vty 0 4
  logging synchronous
  login local
  exit

! --- Loopback ---
interface loopback0
  ip address 10.255.35.6 255.255.255.255
  ip ospf 100 area 0

! --- OSPF Process ---
router ospf 100
  router-id 10.255.35.6
 
  ! Area 0 summary (core)
  area 0 range 10.35.0.0 255.255.255.192
 
  ! Area 2 summary (bottom-left cluster)
  area 2 range 10.35.2.96 255.255.255.224

  ! Area 3 summary (bottom-right cluster)
  area 3 range 10.35.3.128 255.255.255.224

! --- iBGP ---
router bgp 65501
  bgp log-neighbor-changes
  bgp cluster-id 1

  neighbor 10.255.35.1 remote-as 65501
  neighbor 10.255.35.2 remote-as 65501
  neighbor 10.255.35.3 remote-as 65501
  neighbor 10.255.35.4 remote-as 65501
  neighbor 10.255.35.5 remote-as 65501
  neighbor 10.255.35.7 remote-as 65501
  neighbor 10.255.35.8 remote-as 65501
  neighbor 10.255.35.9 remote-as 65501
  neighbor 10.255.35.10 remote-as 65501
  neighbor 10.255.35.11 remote-as 65501
  neighbor 10.255.35.12 remote-as 65501
  neighbor 10.255.35.13 remote-as 65501
  neighbor 10.255.35.14 remote-as 65501
  
  neighbor 10.255.35.1 update-source loopback0
  neighbor 10.255.35.2 update-source loopback0
  neighbor 10.255.35.3 update-source loopback0
  neighbor 10.255.35.4 update-source loopback0
  neighbor 10.255.35.5 update-source loopback0
  neighbor 10.255.35.7 update-source loopback0
  neighbor 10.255.35.8 update-source loopback0
  neighbor 10.255.35.9 update-source loopback0
  neighbor 10.255.35.10 update-source loopback0
  neighbor 10.255.35.11 update-source loopback0
  neighbor 10.255.35.12 update-source loopback0
  neighbor 10.255.35.13 update-source loopback0
  neighbor 10.255.35.14 update-source loopback0
  
  neighbor 10.255.35.1 next-hop-self
  neighbor 10.255.35.2 next-hop-self
  neighbor 10.255.35.3 next-hop-self
  neighbor 10.255.35.4 next-hop-self
  neighbor 10.255.35.5 next-hop-self
  neighbor 10.255.35.7 next-hop-self
  neighbor 10.255.35.8 next-hop-self
  neighbor 10.255.35.9 next-hop-self
  neighbor 10.255.35.10 next-hop-self
  neighbor 10.255.35.11 next-hop-self
  neighbor 10.255.35.12 next-hop-self
  neighbor 10.255.35.13 next-hop-self
  neighbor 10.255.35.14 next-hop-self
  
  neighbor 10.255.35.1 route-reflector-client
  neighbor 10.255.35.2 route-reflector-client
  neighbor 10.255.35.3 route-reflector-client
  neighbor 10.255.35.4 route-reflector-client
  neighbor 10.255.35.5 route-reflector-client
